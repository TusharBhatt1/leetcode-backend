{
	"compilerOptions": {
	  "module": "CommonJS",
	  "moduleResolution": "Node",
	  "target": "ES2022",
  
	  "baseUrl": ".",
	  "paths": {
		"@/*": ["src/*"],
		"~/*": ["app/*"]
	  },
  
	  "rootDir": ".",
	  "outDir": "./dist",
  
	  "esModuleInterop": true,
	  "strict": true
	},
	"include": ["src"]
}