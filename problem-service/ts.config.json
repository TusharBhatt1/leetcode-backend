{
	"compilerOptions": {
	  "module": "NodeNext",
	  "moduleResolution": "NodeNext",
	  "target": "ES2022",
	  "types": ["node"],
	  "allowJs": true,
	  "checkJs": true,
	  "strict": true,
	  "noImplicitAny": false,
	  "noImplicitThis": true,
	  "noImplicitReturns": true,
	  "outDir": "./dist",
	  "rootDir": "./"
	}
  }